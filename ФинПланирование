		|ГДЕ
		|	бит_ДополнительныеУсловияПоДоговору.Ссылка = &Ссылка	
		|";	
	
	Запрос.УстановитьПараметр("Ссылка", Документ.ДопУсловияПоДоговору.Ссылка); 
	
	РезультатЗапроса	= Запрос.Выполнить();
	
