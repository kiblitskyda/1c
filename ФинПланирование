&НаСервере
Процедура ОбновитьГрафикИзОбъекта(УИДНовойСтроки = Неопределено)

	СоответствиеНомеровНовыхСтрокИУидов = ПолучитьСоответствиеНомеровНовыхСтрокИУидов(мГрафикПоступлений.Выгрузить(, "УИДСтроки, ПорядокНовыхСтрок"), мГрафикПоступлений);

	ДанныеГрафика = _ДокументПрогнозированияМенеджер.ПолучитьГрафикиПоступленийДляФормы(Объект, СоответствиеНомеровНовыхСтрокИУидов);
	
	Если Не УИДНовойСтроки = Неопределено Тогда
		ПрисвоитьПорядокНовыхСтрок(ДанныеГрафика, УИДНовойСтроки);
	КонецЕсли;
	ДанныеГрафика.Сортировать("ПорядокНовыхСтрок, Период");

	НомерСтроки = 0;
	Для каждого Строка Из ДанныеГрафика Цикл
		НомерСтроки = НомерСтроки + 1;	
		Строка.НомерСтрокиДляОтображения = НомерСтроки;
	КонецЦикла;	
	
	
	мГрафикПоступлений.Очистить();
	мГрафикПоступлений.Загрузить(ДанныеГрафика);
	
