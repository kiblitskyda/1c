&НаСервере
Процедура ПрисвоитьПорядокНовыхСтрок (ДанныеГрафика, УИДСтроки)
	
	ТЗ = ДанныеГрафика.Скопировать(,"УИДСтроки, ПорядокНовыхСтрок");
	
	Если тз.Количество()=0 Тогда
		Возврат;
	КонецЕсли;
	
	тз.Сортировать("ПорядокНовыхСтрок Убыв");
	МаксНомер = тз[0].ПорядокНовыхСтрок;
	НовыйНомер = МаксНомер + 1;
	
	Для каждого Строка Из ДанныеГрафика Цикл
		Если Строка.УИДСтроки = УИДСтроки Тогда
			Строка.ПорядокНовыхСтрок = НовыйНомер;
			Возврат;
		КонецЕсли;	
	КонецЦикла;	

