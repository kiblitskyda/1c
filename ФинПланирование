		|ВЫБРАТЬ
		|	_ПрогнозПлатежейГрафик.ДокументОснование,
		|	СтатусыОбъектов_Статус.Статус
		|ПОМЕСТИТЬ ВТ_Прогнозы
		|ИЗ
		|	Документ._ПрогнозПлатежей.График КАК _ПрогнозПлатежейГрафик
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СтатусыОбъектов КАК СтатусыОбъектов_Статус
		|		ПО (СтатусыОбъектов_Статус.Объект = _ПрогнозПлатежейГрафик.ДокументОснование)
		|ГДЕ
		|	_ПрогнозПлатежейГрафик.Ссылка = &Ссылка
		|	И _ПрогнозПлатежейГрафик.ДокументОснование ССЫЛКА Документ.бит_ЗаявкаНаРасходованиеСредствОбщая
		|	И _ПрогнозПлатежейГрафик.ДокументОснование <> ЗНАЧЕНИЕ(Документ.бит_ЗаявкаНаРасходованиеСредствОбщая.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_Прогнозы.ДокументОснование
		|ИЗ
		|	ВТ_Прогнозы КАК ВТ_Прогнозы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СтатусыДляУтверждения КАК ВТ_СтатусыДляУтверждения
		|		ПО (ВТ_СтатусыДляУтверждения.Статус = ВТ_Прогнозы.Статус)";

	Запрос.УстановитьПараметр("Ссылка", ПДДССсылка); 
	Запрос.УстановитьПараметр("ИмяОбъекта", "бит_ЗаявкаНаРасходованиеСредствОбщая");
	
	Возврат Запрос.Выполнить();	

КонецФункции

Функция МассовоЗавизироватьПрогнозыВПДДС(ПДДССсылка) Экспорт

	ВсёХорошо 		= Истина;
	СписокСообщений = Новый СписокЗначений;	
	
	РезультатЗапроса = ПолучитьСписокНезавизированныхПрогнозовПлатежейВПДДС(ПДДССсылка);
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		РезультатВизирования = ЗавизироватьПрогноз(Выборка.ДокументОснование);	
		Если Не РезультатВизирования.ВсёХорошо Тогда
			ВсёХорошо = Ложь;
			Для каждого Элемент Из РезультатВизирования.СписокСообщений Цикл
				СписокСообщений.Добавить(Элемент.Значение);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
 	СтруктураРезультат = Новый Структура;
	СтруктураРезультат.Вставить("ВсёХорошо", ВсёХорошо);
	СтруктураРезультат.Вставить("СписокСообщений", СписокСообщений);
	
	Возврат СтруктураРезультат;
	
КонецФункции 

Функция ЗавизироватьПрогноз(ОбъектВизированияСсылка) Экспорт
	
	ВсёХорошо 		= Истина;
	СписокСообщений = Новый СписокЗначений;
	
	флЕстьИзменения = Ложь;

	ОбъектВизирования = ОбъектВизированияСсылка.ПолучитьОбъект();
    Решение = Справочники.бит_ВидыРешенийСогласования.НайтиПоКоду("000000001");
	Комментарий = "Виза установлена при визировании ПДДС";
	
	ТекущийПользователь  = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("глТекущийПользователь");
	ВизыРезультатОбщий   = бит_Визирование.ВыполнитьЗапросДляПолученияВизПользователя(ТекущийПользователь);
	
	
	МассивДокументов = Новый Массив;
	МассивДокументов.Добавить(ОбъектВизированияСсылка);
	
	ТаблицаВизыОбщая = ПолучитьОбщуюТаблицуВиз(МассивДокументов);

	ТекНаборВизы = РегистрыСведений.бит_УстановленныеВизы.СоздатьНаборЗаписей();
	ТаблицаВизыПустая = ТекНаборВизы.Выгрузить();
	
	
	ВизыПользователя = бит_Визирование.ПолучитьВизыПользователя(ТекущийПользователь
	                                                             ,ОбъектВизированияСсылка
																 ,ВизыРезультатОбщий);
	
	//флЕстьНеустановленные
	ЗаполнитьТаблицуВиз(ТаблицаВизыПустая
	                     ,ОбъектВизированияСсылка
						 ,ТаблицаВизыОбщая
						 ,ВизыПользователя);															 
																 
						 
	ТаблицаВизы = ТаблицаВизыПустая.Скопировать();
	
	Алгоритм = бит_Визирование.ПолучитьАлгоритмПоНаборуВиз(ТаблицаВизы);
	
	КэшТаблицТочек = Новый Соответствие;
	ТаблицаТочек = КэшТаблицТочек[Алгоритм];
	Если ТаблицаТочек = Неопределено Тогда
		ТаблицаТочек = бит_уп_Сервер.ПолучитьТочкиАлгоритма(Алгоритм);
		КэшТаблицТочек.Вставить(Алгоритм,ТаблицаТочек);
	КонецЕсли;	
	
	локТаблицаТочкиВизы  = бит_уп_Сервер.ПолучитьТаблицуТочек(Алгоритм,ТаблицаВизы,ТаблицаТочек);
	
    флВыполнятьПоэтапно = бит_уп_Сервер.ВыполнятьАлгоритмПоэтапно(Алгоритм);				
	бит_уп_Сервер.ОпределитьДоступностьТочек(локТаблицаТочкиВизы,флВыполнятьПоэтапно);

	СтрОтбор = Новый Структура;
	СтрОтбор.Вставить("Доступность",Истина);
	МассивСтрок = локТаблицаТочкиВизы.НайтиСтроки(СтрОтбор);
	
	МассивДоступныеПустые = Новый Массив;
	МассивДоступныеЗаполненные = Новый Массив;
	
	Для каждого СтрокаТаблицы Из МассивСтрок Цикл
		Если СтрокаТаблицы.Доступность  Тогда
			Если ЗначениеЗаполнено(СтрокаТаблицы.Решение) Тогда
				МассивДоступныеЗаполненные.Добавить(СтрокаТаблицы.ИД);
			Иначе	
				МассивДоступныеПустые.Добавить(СтрокаТаблицы.ИД);
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла; 
	
	СтруктураОтбор = Новый Структура;
	СтруктураОтбор.Вставить("Объект", ОбъектВизированияСсылка);
	ТекНаборВизы = бит_Визирование.ПрочитатьНаборВиз(СтруктураОтбор);
	
	флРазрешеноУстанавливать = Истина;	
	
	Для каждого ЗаписьВизы Из ТекНаборВизы Цикл
		Если ЗначениеЗаполнено(Решение) Тогда
			Если НЕ МассивДоступныеПустые.Найти(ЗаписьВизы.ИД) = Неопределено Тогда
				Если флРазрешеноУстанавливать Тогда
					флЕстьИзменения = Истина;
					ЗаписьВизы.Решение       = Решение;
					ЗаписьВизы.Пользователь  = ТекущийПользователь;
					ЗаписьВизы.ДатаУстановки = ТекущаяДата();
					ЗаписьВизы.Комментарий   = Комментарий;
				КонецЕсли; 
			КонецЕсли; 
		Иначе	
			Если НЕ МассивДоступныеЗаполненные.Найти(ЗаписьВизы.ИД) = Неопределено Тогда
				флЕстьИзменения = Истина;
				ЗаписьВизы.Решение       = Справочники.бит_ВидыРешенийСогласования.ПустаяСсылка();
				ЗаписьВизы.Пользователь  = Справочники.Пользователи.ПустаяСсылка();
				ЗаписьВизы.ДатаУстановки = Дата('00010101');
				ЗаписьВизы.Комментарий   = Комментарий;
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла; 
	
	Если флЕстьИзменения Тогда 
		
		ДокОбъект = ОбъектВизирования;
		МетаОбъект = ДокОбъект.Метаданные();
        флПроводитьПослеУтверждения = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_ПроводитьДокументыПослеУтверждения");								
		бит_Визирование.ДовыполнитьАлгоритмВизирования(ОбъектВизированияСсылка,ТекНаборВизы,Ложь);
		
		Если ЗначениеЗаполнено(Решение) Тогда
			бит_Визирование.УстановитьКрайниеДатыВизирования(ОбъектВизированияСсылка,ТекНаборВизы,Ложь);
		КонецЕсли; 
		
		НачатьТранзакцию();
		
		Попытка
			ТекНаборВизы.Записать();
			флДействиеВыполнено = Истина;                              
		Исключение
			ВсёХорошо = Ложь;
			ТекстСообщения = СтрШаблон("Ошибка записи виз! %1, %2", ОбъектВизированияСсылка, ОписаниеОшибки());
			СписокСообщений.Добавить(ТекстСообщения);
		КонецПопытки;
		
		Если ВсёХорошо Тогда 
			Попытка
				ДокОбъект.УстановитьСтатус();
			    бит_Визирование.ПровестиВСтатусеУтверждено(ДокОбъект, МетаОбъект, флПроводитьПослеУтверждения, "Ошибки");
			Исключение
				ВсёХорошо = Ложь;
				ТекстСообщения = СтрШаблон("Не удалось провести с установкой статуса! %1", ОбъектВизированияСсылка);
				СписокСообщений.Добавить(ТекстСообщения);
			КонецПопытки;
		КонецЕсли;
		
		Если ВсёХорошо Тогда
			ЗафиксироватьТранзакцию();
		Иначе
		    ОтменитьТранзакцию();
		КонецЕсли;
	
	Иначе
		
		ВсёХорошо = Ложь;
		ТекстСообщения = СтрШаблон("Не установлена виза, отсутствуют настройки визирования для пользователя! %1, %2", ОбъектВизированияСсылка, ОписаниеОшибки());
		СписокСообщений.Добавить(ТекстСообщения);
	КонецЕсли; 
	
	СтруктураРезультат = Новый Структура;
	СтруктураРезультат.Вставить("ВсёХорошо", ВсёХорошо);
	СтруктураРезультат.Вставить("СписокСообщений", СписокСообщений);
	
	Возврат СтруктураРезультат;
	
КонецФункции 

Функция ПолучитьОбщуюТаблицуВиз(МассивДокументов)

	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("МассивДокументов",МассивДокументов);
	Запрос.Текст = "ВЫБРАТЬ
	               |	бит_УстановленныеВизы.Объект,
	               |	бит_УстановленныеВизы.Виза,
	               |	бит_УстановленныеВизы.ИД,
	               |	бит_УстановленныеВизы.Пользователь,
	               |	бит_УстановленныеВизы.ФизическоеЛицо,
	               |	бит_УстановленныеВизы.ДобавленаВручную,
	               |	бит_УстановленныеВизы.ДатаУстановки,
	               |	бит_УстановленныеВизы.КодСортировки,
	               |	бит_УстановленныеВизы.Должность,
	               |	бит_УстановленныеВизы.Комментарий,
	               |	бит_УстановленныеВизы.Статус,
	               |	бит_УстановленныеВизы.Решение,
	               |	бит_УстановленныеВизы.Маршрут,
	               |	бит_УстановленныеВизы.Алгоритм,
	               |	бит_УстановленныеВизы.ТочкаАлгоритма,
	               |	бит_УстановленныеВизы.ДатаКрайняя,
	               |	бит_УстановленныеВизы.ВремяНаУстановку
	               |ИЗ
	               |	РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы  
	               |ГДЕ
	               |	бит_УстановленныеВизы.Объект В(&МассивДокументов)";
				   
				   
    Результат = Запрос.Выполнить();
				   
	ТаблицаВизыОбщая = Результат.Выгрузить();			   

	Возврат ТаблицаВизыОбщая;
	
КонецФункции // ПолучитьОбщуюТаблицуВиз()

Функция ЗаполнитьТаблицуВиз(ТаблицаВизы,ДокументСсылка,ТаблицаВизыОбщая,ВизыПользователя)

	флЕстьНеустановленные = Ложь;
	
	Отбор = Новый Структура;
	Отбор.Вставить("Объект",ДокументСсылка);
	
	МассивСтрок = ТаблицаВизыОбщая.НайтиСтроки(Отбор);
	Для каждого СтрокаТаблицы Из МассивСтрок Цикл
		НоваяСтрока = ТаблицаВизы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаТаблицы);
	КонецЦикла; 
	
	// Реквизит4 определяет доступность визы. Текст, т.к. в упр. форме нельзя сменить тип
	ТаблицаВизы.Колонки.Добавить("Реквизит4",Новый ОписаниеТипов("Строка"));
	// заполним Реквизит4
	Для каждого СтрокаТаблицы Из ТаблицаВизы Цикл
		Если НЕ ВизыПользователя.НайтиПоЗначению(СтрокаТаблицы.Виза) = Неопределено Тогда
			 СтрокаТаблицы.Реквизит4 = "ИСТИНА"; 
		ИначеЕсли НЕ ВизыПользователя.НайтиПоЗначению(Справочники.бит_ГруппыВиз.ВсеВизы) = Неопределено Тогда
			 СтрокаТаблицы.Реквизит4 = "ИСТИНА";
		КонецЕсли; 
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Решение) Тогда
			флЕстьНеустановленные = Истина;
		КонецЕсли; 
	КонецЦикла; 

	Возврат флЕстьНеустановленные;
	
КонецФункции
	
