&НаКлиенте
Процедура нГрафикПоступленийПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Отказ = Истина;  
	СтрокаТЧ = Элементы.нГрафикПоступлений.ТекущиеДанные; 

	Если Копирование Тогда 
	    ТекущаяСтрока = Элементы.нГрафикПоступлений.ТекущиеДанные;
	    Если ТекущаяСтрока = Неопределено Тогда
	        Сообщить("Выберите строку для копирования");
	        Возврат;
	    КонецЕсли;		
		
		УИДНовойСтроки = СкопироватьСтрокуГрафикаПоступленийБНаСервере(ТекущаяСтрока.УИДСтроки);
		
	Иначе
		УИДНовойСтроки = СоздатьСтрокуГрафикаПоступленийБНаСервере();  
		
	КонецЕсли; 
	
    ВосстановитьФокусНаСтрокеГрафикаПоступленийБ(УИДНовойСтроки);

