&НаКлиенте
Процедура УстановитьПредставлениеБездоговорнойСхемы()

	БездоговорнаяСхема 	= _ДокументПрогнозированияМенеджер.ЭтоБездоговорнаяСхема(Объект.Ссылка);
	ДоговорнаяСхема		= Не БездоговорнаяСхема;
	Расходная 			= ?(Объект.ДопУсловияПоДоговору.РасходДоход = Перечисления.бит_РасходДоход.Расходование	, 	Истина, Ложь); 
	Доходная 			= ?(Объект.ДопУсловияПоДоговору.РасходДоход = Перечисления.бит_РасходДоход.Поступление	, 	Истина, Ложь);
	
	Если Расходная и БездоговорнаяСхема 	Тогда 
		мКэшЗначений.ПредставлениеОбъекта 		= "План исполнения бюджета (бездоговорная расходная схема)";
		Элементы.Контрагент.Видимость 			= Ложь;
		Элементы.ДоговорКонтрагента.Видимость 	= Ложь;
		Элементы.Бюджет.Видимость 				= Истина;		
	ИначеЕсли Доходная и БездоговорнаяСхема Тогда
		мКэшЗначений.ПредставлениеОбъекта 		= "План исполнения бюджета (бездоговорная доходная схема)";
		Элементы.Контрагент.Видимость 			= Ложь;
		Элементы.ДоговорКонтрагента.Видимость 	= Ложь;
		Элементы.Бюджет.Видимость 				= Истина;		
	ИначеЕсли Расходная и ДоговорнаяСхема 	Тогда
		мКэшЗначений.ПредставлениеОбъекта 		= "План исполнения договора (договорная расходная схема)";
	ИначеЕсли Доходная и ДоговорнаяСхема 	Тогда
		мКэшЗначений.ПредставлениеОбъекта 		= "План исполнения договора (договорная доходная схема)";
	КонецЕсли;

КонецПроцедуры

 &НаКлиенте
Процедура УстановитьВидимостьВкладок()

	БездоговорнаяСхема 	= _ДокументПрогнозированияМенеджер.ЭтоБездоговорнаяСхема(Объект.Ссылка);
	ДоговорнаяСхема		= Не БездоговорнаяСхема;
	Расходная 			= ?(Объект.ДопУсловияПоДоговору.РасходДоход = Перечисления.бит_РасходДоход.Расходование	, 	Истина, Ложь); 
	Доходная 			= ?(Объект.ДопУсловияПоДоговору.РасходДоход = Перечисления.бит_РасходДоход.Поступление	, 	Истина, Ложь);
	
	Если Расходная и БездоговорнаяСхема 		Тогда
		Элементы.ГруппаГрафикПлатежей.Видимость 				= Ложь;	
		Элементы.ГруппаГрафикПлатежейБездоговорная.Видимость 	= Истина;	
		Элементы.ГруппаГрафикПоступлений.Видимость 				= Ложь;	
		Элементы.ГруппаГрафикПоступленийБездоговорная.Видимость = Ложь;
		Элементы.ГруппаСтраницы.ТекущаяСтраница 				= Элементы.ГруппаГрафикПлатежейБездоговорная;
	ИначеЕсли Доходная и БездоговорнаяСхема 	Тогда
		Элементы.ГруппаГрафикПлатежей.Видимость 				= Ложь;	
		Элементы.ГруппаГрафикПлатежейБездоговорная.Видимость 	= Ложь;	
		Элементы.ГруппаГрафикПоступлений.Видимость 				= Ложь;	
		Элементы.ГруппаГрафикПоступленийБездоговорная.Видимость = Истина;
		Элементы.ГруппаСтраницы.ТекущаяСтраница 				= Элементы.ГруппаГрафикПоступленийБездоговорная;
	ИначеЕсли Расходная и ДоговорнаяСхема 		Тогда
		Элементы.ГруппаГрафикПлатежей.Видимость 				= Истина;	
		Элементы.ГруппаГрафикПлатежейБездоговорная.Видимость 	= Ложь;	
		Элементы.ГруппаГрафикПоступлений.Видимость 				= Ложь;	
		Элементы.ГруппаГрафикПоступленийБездоговорная.Видимость = Ложь;
		Элементы.ГруппаСтраницы.ТекущаяСтраница 				= Элементы.ГруппаГрафикПлатежей;
	ИначеЕсли Доходная и ДоговорнаяСхема 		Тогда
		Элементы.ГруппаГрафикПлатежей.Видимость 				= Ложь;	
		Элементы.ГруппаГрафикПлатежейБездоговорная.Видимость	= Ложь;	
		Элементы.ГруппаГрафикПоступлений.Видимость 				= Истина;	
		Элементы.ГруппаГрафикПоступленийБездоговорная.Видимость = Ложь;
		Элементы.ГруппаСтраницы.ТекущаяСтраница 				= Элементы.ГруппаГрафикПоступлений;
	Иначе
		Элементы.ГруппаГрафикПлатежей.Видимость 				= Истина;	
		Элементы.ГруппаГрафикПлатежейБездоговорная.Видимость 	= Истина;	
		Элементы.ГруппаГрафикПоступлений.Видимость 				= Истина;	
		Элементы.ГруппаГрафикПоступленийБездоговорная.Видимость = Истина;
		Элементы.ГруппаСтраницы.ТекущаяСтраница 				= Элементы.ГруппаОсновные;
	КонецЕсли;

