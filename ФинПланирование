				НовоеСообщение = ?(НовоеСообщение="", 
				СтрШаблон("Для строки %1 найдено более одного платежного поручения: %2 от %3", 
				Строка.НомерСтроки, 
				ВыборкаДетальныеЗаписи.ГрафикПлатежей.Номер,
