	Иначе
		УИДНовойСтроки = СоздатьСтрокуГрафикаПлатежейБНаСервере();  
	КонецЕсли; 
	
    ВосстановитьФокусНаСтрокеГрафикПлатежейБ(УИДНовойСтроки);

