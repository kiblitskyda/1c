		Возврат Истина;
	КонецЕсли;
	
	Для каждого Строка Из ПДДССсылка.График Цикл
		Если 
			ТипЗнч(Строка.ДокументОснование) <> тип("ДокументСсылка.бит_ЗаявкаНаРасходованиеСредствОбщая") 
			и
			ТипЗнч(Строка.ДокументОснование) <> тип("ДокументСсылка.бит_ПланируемоеПоступлениеДенежныхСредств") 
		Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;	
	
	Возврат Истина;

