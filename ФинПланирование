	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ГН.СтатьяОборотовНачисления
	|ПОМЕСТИТЬ ВТ_СписокСтатейБДР
	|ИЗ
