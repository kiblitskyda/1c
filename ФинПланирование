&НаКлиенте
Процедура ВосстановитьФокусНаСтрокеГрафикаПоступленийБ(УИДСтроки)
    
    // Ищем строку с этим УИД в обновленной таблице
    Для Каждого Строка Из нГрафикПоступлений Цикл
        Если Строка.УИДСтроки = УИДСтроки Тогда
            Элементы.нГрафикПоступлений.ТекущаяСтрока = Строка.ПолучитьИдентификатор();
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
КонецПроцедуры 

&НаКлиенте
Процедура нГрафикПоступленийПриИзменении(Элемент)
	
	Если Элемент.ТекущийЭлемент.Имя = "нГрафикПоступленийПакетнаяОбработка" Тогда
		Возврат;
	КонецЕсли;

	Модифицированность = Истина;
    ТекущаяСтрока = Элемент.ТекущиеДанные;
    Если ТекущаяСтрока = Неопределено Тогда
        Возврат;
    КонецЕсли; 
    
    // ЗАПОМИНАЕМ текущую строку
    УИДТекущейСтроки = ТекущаяСтрока.УИДСтроки;
    
    ОбновитьСтроку_ГрафикаПоступленийБНаСервере(УИДТекущейСтроки);
    
	//// Перезагружаем график
	ЗаполнитьГрафикПоступленийБНаСервере();
    
    // ВОССТАНАВЛИВАЕМ фокус
    ВосстановитьФокусНаСтрокеГрафикаПоступленийБ(УИДТекущейСтроки);
	
КонецПроцедуры 

&НаСервере
Процедура ОбновитьСтроку_ГрафикаПоступленийБНаСервере(УИДСтроки)
	
	ТТЗ = РеквизитФормыВЗначение("нГрафикПоступлений");	
	РезультатОбновления = _ДокументПрогнозированияМенеджер.ОбновитьСтрокуГрафикаНаСервере(Объект, УИДСтроки, ТТЗ);	
	
	Если Не РезультатОбновления.ВсеХорошо Тогда
		Сообщить(СтрСоединить(РезультатОбновления.СписокСообщений));
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура нГрафикПоступленийПередНачаломИзменения(Элемент, Отказ)
	
	ТекущаяСтрокаГрафика = Элементы.нГрафикПоступлений.ТекущиеДанные; 
	
	Если ТекущаяСтрокаГрафика = Неопределено Тогда
		Возврат;
	КонецЕсли;                                                         
	
	Если Элемент.ТекущийЭлемент.Имя = "нГрафикПоступленийПакетнаяОбработка" Тогда
		Возврат;
	КонецЕсли;	

	Если Элемент.ТекущийЭлемент.Имя = "нГрафикПоступленийДокументПланирования" Тогда
		ПоказатьЗначение(,ТекущаяСтрокаГрафика.ДокументПланирования);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущаяСтрокаГрафика.ДокументПланирования) Тогда
		Сообщить("Редактирование запрещено: по строке создан документ планирования " + 
		         ТекущаяСтрокаГрафика.ДокументПланирования);
        Отказ = Истина;
        Возврат;
	КонецЕсли;	

	Если ТекущаяСтрокаГрафика.Период < НачалоДня(ТекущаяДата()) Тогда
		Сообщить("Редактирование запрещено: дата в прошлом. Возможно создание Планируемого поступления");
	    Отказ = Истина;
	    Возврат;
	КонецЕсли;
	
	//ПлатежиБЦФОЗаполнитьСписокВыбора();
	//ПлатежиБМероприятияЗаполнитьСписокВыбора();
	ГрафикПоступленийБЗаполнитьСтатьиДДСДляВыбора();
	
	Элементы.нГрафикПоступленийДокументПланирования.СписокВыбора.Очистить();
	Элементы.нГрафикПоступленийДокументПланирования.СписокВыбора.Добавить(ТекущаяСтрокаГрафика.ДокументПланирования);
	
