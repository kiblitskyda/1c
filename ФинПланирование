&НаСервере
Процедура ОбновитьГрафикПлатежейИзОбъекта(УИДНовойСтроки = Неопределено)
	
	СоответствиеНомеровНовыхСтрокИУидов = ПолучитьСоответствиеНомеровНовыхСтрокИУидов(мГрафикПлатежей.Выгрузить(, "УИДСтроки, ПорядокНовыхСтрок"), мГрафикПлатежей);
	
	мГрафикПлатежей.Очистить();
	ТЗ = мГрафикПлатежей.Выгрузить();

	ДанныеГрафика = _ДокументПрогнозированияМенеджер.ПолучитьГрафикПлатежейДляФормы(Объект, ТЗ, СоответствиеНомеровНовыхСтрокИУидов);
	
	Если Не УИДНовойСтроки = Неопределено Тогда
		ПрисвоитьПорядокНовыхСтрок(ДанныеГрафика, УИДНовойСтроки);
	КонецЕсли;
	ДанныеГрафика.Сортировать("ПорядокНовыхСтрок, Период");
	НомерСтроки = 0;
	Для каждого Строка Из ДанныеГрафика Цикл
		НомерСтроки = НомерСтроки + 1;	
		Строка.НомерСтрокиДляОтображения = НомерСтроки;
	КонецЦикла;
	
	мГрафикПлатежей.Очистить();
	мГрафикПлатежей.Загрузить(ДанныеГрафика);

	Итоги = _ДокументПрогнозированияМенеджер.РассчитатьИтогиПоГрафикуПлатежей(Объект, ТЗ);
	РассчитатьИтогиПоГрафикуПлатежейНаСервере(Итоги);
	
