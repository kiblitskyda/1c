		ЭтотОбъект.ВремяПоследнихИзменений 		= ТекущаяДата();
		ЭтотОбъект.Сценарий 			= Справочники.СценарииПланирования.ПРОГНОЗ_ЦФО;
		ЭтотОбъект.Основание			= ДополнительныеУсловияПоДоговору;
		Если ЗначениеЗаполнено(ЭтотОбъект.ДопУсловияПоДоговору.ПроектДоговора) Тогда
			ЭтотОбъект.ЗакупкаГКПЗ			= ЭтотОбъект.ДопУсловияПоДоговору.ПроектДоговора._ЗакупкаГКПЗ; 
		КонецЕсли;
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка._ДокументПрогнозирования") тогда
		ДокументОснование				= ДанныеЗаполнения;	
		ЭтотОбъект.ДопУсловияПоДоговору = ДокументОснование.ДопУсловияПоДоговору;
		ЭтотОбъект.Дата 				= ТекущаяДата();
		ЭтотОбъект.АвторПоследнихИзменений 		= ПараметрыСеанса.ТекущийПользователь;
		ЭтотОбъект.ВремяПоследнихИзменений 		= ТекущаяДата();
