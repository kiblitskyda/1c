Процедура ПроверитьОбъектыСтроительстваПоСтатьямОборотовПКВ(Отказ)

	ВывестиСписокСтатейОборотов = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПредопределенныеЗначенияСписок.Элемент
		|ИЗ
		|	Справочник.ПредопределенныеЗначения.Список КАК ПредопределенныеЗначенияСписок
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПредопределенныеЗначения КАК ПредопределенныеЗначения
		|		ПО ПредопределенныеЗначенияСписок.Ссылка = ПредопределенныеЗначения.Ссылка
		|ГДЕ
		|	ПредопределенныеЗначения.Идентификатор = &Идентификатор";
	
	Запрос.УстановитьПараметр("Идентификатор", "СтатьиОборотовПКВ");
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	Для каждого Строка Из ЭтотОбъект.ГрафикНачислений Цикл
		Если 
			Не Тз.Найти(Строка.Аналитика_7.СтатьяОборотов, "Элемент") = Неопределено  
			и 
			Строка(строка.Аналитика_2) = ""
			и
			Год(Строка.Период) >= 2024
		Тогда
			Отказ = Истина;            
			ВывестиСписокСтатейОборотов = Истина;
			СтрСообщения = СтрШаблон("Строка %1, не заполнен объект строительства!", Строка.НомерСтроки );
			Сообщить (СтрСообщения);
		КонецЕсли;
	КонецЦикла;
	
	Если ВывестиСписокСтатейОборотов и ТЗ.Количество()>0 Тогда
		Сообщить ("Заполнение объектов строительства обязательно для следующих статей оборотов:");
		Для каждого  Строка Из  ТЗ Цикл
			Сообщить(символы.Таб + Строка.Элемент);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

