	//Элементы.нГрафикПоступленийСуммаПлатежа.ТекстПодвала 				= Формат(ДанныеГрафика.Итог("СуммаПлатежа"), "ЧДЦ=2"); 
	Элементы.нГрафикПоступленийПрогноз.ТекстПодвала 					= Формат(ДанныеГрафика.Итог("Прогноз"), "ЧДЦ=2"); 
	//Элементы.нГрафикПоступленийФакт.ТекстПодвала 						= Формат(ДанныеГрафика.Итог("Факт"), "ЧДЦ=2"); 
	
	ПересчитатьШапкуГрафикаПоступленийБ(ДанныеГрафика);
	
