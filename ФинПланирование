&НаКлиенте
Процедура нГрафикПоступленийПередУдалением(Элемент, Отказ) 
	
	Отказ = Истина;
    
    ТекущаяСтрока = Элементы.нГрафикПоступлений.ТекущиеДанные;
    Если ТекущаяСтрока = Неопределено Тогда
        Возврат;
	КонецЕсли; 
	
	// Проверяем документ планирования
	Если ЗначениеЗаполнено(ТекущаяСтрока.ДокументПланирования) Тогда
	    Сообщить("Удаление запрещено: по строке создан документ планирования " + 
	             ТекущаяСтрока.ДокументПланирования);
	    Возврат;
	КонецЕсли;
	
	Если ТекущаяСтрока.Период < НачалоДня(ТекущаяДата()) Тогда
	    Сообщить("Удаление запрещено: дата в прошлом");
	    Возврат;
	КонецЕсли;	
	    
    // 1. ЗАПОМИНАЕМ ПОЗИЦИЮ в таблице (индекс строки)
    ПозицияВТаблице = Неопределено;
    Для i = 0 По нГрафикПоступлений.Количество() - 1 Цикл
        Если нГрафикПоступлений[i].УИДСтроки = ТекущаяСтрока.УИДСтроки Тогда
            ПозицияВТаблице = i; // Номер строки сверху (0, 1, 2...)
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
    // 2. УДАЛЯЕМ
    УдалитьСтрокуГрафикаПоступленийБНаСервере(ТекущаяСтрока.УИДСтроки);
    
    // 3. ВОССТАНАВЛИВАЕМ ФОКУС НА ТОЙ ЖЕ ПОЗИЦИИ
    Если ПозицияВТаблице <> Неопределено Тогда
        
        Если нГрафикПоступлений.Количество() = 0 Тогда
            // Если строк не осталось
            Возврат;
        КонецЕсли;
        
        // Выбираем строку на ТОЙ ЖЕ ПОЗИЦИИ
        // Если позиция больше, чем строк осталось — берём последнюю
        НоваяПозиция = ?(ПозицияВТаблице < нГрафикПоступлений.Количество(),
                         ПозицияВТаблице,
                         нГрафикПоступлений.Количество() - 1);
        
        // Ищем строку по позиции и ставим фокус
        Если НоваяПозиция < нГрафикПоступлений.Количество() Тогда
            СтрокаНаПозиции = нГрафикПоступлений[НоваяПозиция];
            Элементы.нГрафикПоступлений.ТекущаяСтрока = СтрокаНаПозиции.ПолучитьИдентификатор();
        КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры 

